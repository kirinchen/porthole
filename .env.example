# porthole 設定範本 — 複製成 .env 後填入(.env 不進 git)。
#   cp .env.example .env
# 由 server/env.ts 在啟動時載入。systemd 部署時別在 unit 再設這些,
# 否則會壓過 .env(loadEnvFile 不覆寫既有 env)。

# 後端綁定位址。預設只綁 127.0.0.1(僅本機)。
#   - 只本機自用      → 127.0.0.1
#   - 從 tailscale 連 → 填你的 tailscale 網卡 IP(如 100.x.x.x),只該裝置網內可達
#   - ⚠️ 0.0.0.0      → 連同 LAN 一起開放。porthole 無認證、CLI=完整 shell(RCE),
#                       只在「完全信任的網路」才這樣綁(見 doc/SPEC.md §2)。
HOST=127.0.0.1

# 監聽 port。
PORT=4321

# repo 掃描根目錄。URL 第一段 repo 名 → <PORTHOLE_BASE>/<repo>。
# 一律經 path-guard 鎖在此目錄內,任何 .. 逃逸 → 403。
PORTHOLE_BASE=/path/to/your/project-base
